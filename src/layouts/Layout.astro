---
import { ViewTransitions } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getLangFromUrl, ogLocales, locales, getLocalizedPath, t, type Locale } from '../i18n/utils';
import { CONTACT } from '../lib/constants';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
}

const { title, description } = Astro.props;
const locale = Astro.props.locale ?? getLangFromUrl(Astro.url);
const canonicalURL = new URL(Astro.url.pathname, 'https://www.digital-factory.lu');
const ogLocale = ogLocales[locale];

// Clean path for hreflang (without locale prefix)
let cleanPath = Astro.url.pathname;
if (locale !== 'fr') {
  cleanPath = cleanPath.replace(`/${locale}`, '') || '/';
}

// JSON-LD Structured Data
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Digital Factory Sàrl-s",
  "url": "https://www.digital-factory.lu",
  "logo": new URL('/images/logo.svg', 'https://www.digital-factory.lu').href,
  "description": "Venture builder SaaS basé au Luxembourg, expert en transformation digitale, numérisation 3D et solutions web sur-mesure.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "3 Rue de la Gare",
    "postalCode": "8308",
    "addressLocality": "Capellen",
    "addressCountry": "LU"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": CONTACT.email1,
    "contactType": "customer service",
    "availableLanguage": ["French", "English", "German", "Luxembourgish"]
  },
  "sameAs": [
    CONTACT.linkedin,
    CONTACT.instagram
  ],
  "areaServed": {
    "@type": "GeoCircle",
    "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 49.6117, "longitude": 6.1319 },
    "geoRadius": "300"
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Digital Factory",
  "url": "https://www.digital-factory.lu",
  "inLanguage": ["fr", "en", "de", "lb"]
};
---

<!doctype html>
<html lang={locale === 'lu' ? 'lb' : locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <link rel="canonical" href={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Digital Factory" />
    <meta property="og:image" content={new URL('/images/og-image.png', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/images/og-image.png', Astro.site).href} />

    <!-- Hreflang -->
    {locales.map((lang) => (
      <link
        rel="alternate"
        hreflang={lang === 'lu' ? 'lb' : lang}
        href={new URL(getLocalizedPath(cleanPath, lang), 'https://www.digital-factory.lu').href}
      />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(getLocalizedPath(cleanPath, 'fr'), 'https://www.digital-factory.lu').href}
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- PWA -->
    <meta name="theme-color" content="#0d9488" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Digital Factory" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />

    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <ViewTransitions />
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden">
    <!-- Skip to content (a11y) -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:bg-teal-600 focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-medium">
      {locale === 'fr' ? 'Aller au contenu' : locale === 'en' ? 'Skip to content' : locale === 'de' ? 'Zum Inhalt springen' : 'Zum Inhalt sprangen'}
    </a>
    <Navbar locale={locale} transition:animate="none" />
    <main id="main-content" class="flex-1 overflow-x-hidden" transition:animate="fade">
      <slot />
    </main>
    <Footer locale={locale} transition:animate="none" />

    <!-- Bandeau cookies RGPD -->
    <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-50 hidden" role="dialog" aria-label="Cookies">
      <div class="bg-gray-900/95 backdrop-blur-sm border-t border-gray-700 px-4 sm:px-6 py-4">
        <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center gap-4 sm:gap-6">
          <p class="text-sm text-gray-300 text-center sm:text-left flex-1">
            {t('cookie.text', locale)}
            <a href={getLocalizedPath('/politique-de-confidentialite', locale)} class="text-teal-400 hover:underline ml-1">{t('cookie.learnMore', locale)}</a>
          </p>
          <div class="flex gap-3 shrink-0">
            <button
              id="cookie-refuse"
              class="border border-gray-500 hover:border-gray-400 text-gray-300 hover:text-white text-sm font-medium px-5 py-2 rounded-full transition-colors"
            >
              {t('cookie.refuse', locale)}
            </button>
            <button
              id="cookie-accept"
              class="bg-teal-600 hover:bg-teal-700 text-white text-sm font-medium px-5 py-2 rounded-full transition-colors"
            >
              {t('cookie.accept', locale)}
            </button>
          </div>
        </div>
      </div>
    </div>

    <script>
      // Service Worker PWA
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }

      // Bandeau cookies RGPD (consentement granulaire)
      function initCookieBanner() {
        const banner = document.getElementById('cookie-banner');
        const acceptBtn = document.getElementById('cookie-accept');
        const refuseBtn = document.getElementById('cookie-refuse');
        if (!banner || !acceptBtn || !refuseBtn) return;

        const consent = localStorage.getItem('cookie-consent');
        if (!consent) {
          banner.classList.remove('hidden');
        }

        function saveConsent(accepted: boolean) {
          const data = {
            necessary: true,
            analytics: accepted,
            timestamp: new Date().toISOString(),
          };
          localStorage.setItem('cookie-consent', JSON.stringify(data));
          banner.classList.add('hidden');
        }

        acceptBtn.addEventListener('click', () => saveConsent(true));
        refuseBtn.addEventListener('click', () => saveConsent(false));
      }
      initCookieBanner();
      document.addEventListener('astro:after-swap', initCookieBanner);

      // Intersection Observer pour les animations fade-in
      function initObserver() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
              }
            });
          },
          { threshold: 0.1 }
        );

        document.querySelectorAll('.fade-in, .fade-in-left, .fade-in-right, .scale-in').forEach((el) => observer.observe(el));
      }

      // Initialiser au chargement et après chaque navigation
      initObserver();
      document.addEventListener('astro:after-swap', initObserver);
    </script>
  </body>
</html>
