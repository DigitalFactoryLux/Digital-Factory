---
import Layout from '../layouts/Layout.astro';
import { EXTERNAL_LINKS } from '../lib/constants';
import { t, tp, getLocalizedPath, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const lang = locale;
---

<Layout title={`TEEQODE® - ${tp('teeqode', 'hero.subtitle', lang)}`} description={tp('teeqode', 'hero.subtitle', lang)}>

  <!-- Hero Section -->
  <section class="relative overflow-hidden min-h-[70vh] md:min-h-[85vh] flex items-center">
    <!-- Fond dégradé emerald dominant (plus intense) -->
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-200 via-emerald-100 to-teal-100"></div>
    <div class="absolute inset-0 bg-gradient-to-tr from-emerald-300/30 via-transparent to-teal-200/20"></div>

    <!-- Blobs décoratifs (emerald plus marqué) -->
    <div class="blob w-64 md:w-[500px] h-64 md:h-[500px] bg-emerald-400/60 -top-20 -right-32" style="animation-delay: 0s;"></div>
    <div class="blob w-48 md:w-96 h-48 md:h-96 bg-emerald-300/50 bottom-20 left-10" style="animation-delay: 2s;"></div>
    <div class="blob w-40 md:w-72 h-40 md:h-72 bg-teal-300/30 top-1/4 right-1/3" style="animation-delay: 4s;"></div>

    <!-- Motif lignes -->
    <div class="absolute inset-0 lines-pattern opacity-40"></div>

    <!-- Vagues animées -->
    <div class="absolute bottom-0 left-0 right-0 pointer-events-none">
      <svg aria-hidden="true" class="absolute bottom-0 w-[200%] animate-wave-slow" viewBox="0 0 2880 180" preserveAspectRatio="none" style="height: 100px;">
        <path d="M0 100C240 140 480 60 720 100C960 140 1200 60 1440 100C1680 140 1920 60 2160 100C2400 140 2640 60 2880 100V180H0Z" fill="rgba(255,255,255,0.3)" />
      </svg>
      <svg aria-hidden="true" class="absolute bottom-0 w-[200%] animate-wave-mid" viewBox="0 0 2880 180" preserveAspectRatio="none" style="height: 80px;">
        <path d="M0 80C200 130 400 40 600 80C800 120 1000 30 1200 80C1400 130 1600 40 1800 80C2000 120 2200 30 2400 80C2600 130 2800 40 2880 80V180H0Z" fill="rgba(255,255,255,0.5)" />
      </svg>
      <svg aria-hidden="true" class="absolute bottom-0 w-[200%] animate-wave-fast" viewBox="0 0 2880 180" preserveAspectRatio="none" style="height: 60px;">
        <path d="M0 90C180 130 360 50 540 90C720 130 900 50 1080 90C1260 130 1440 50 1620 90C1800 130 1980 50 2160 90C2340 130 2520 50 2700 90C2880 130 2880 90 2880 90V180H0Z" fill="white" />
      </svg>
    </div>

    <!-- Illustration droite — Document avec loupe (gestion documentaire) -->
    <div class="absolute right-0 top-1/2 -translate-y-1/2 opacity-20 hidden lg:block pointer-events-none">
      <svg aria-hidden="true" width="500" height="500" viewBox="0 0 500 500" fill="none" class="text-emerald-800">
        <!-- Document principal -->
        <rect x="180" y="120" width="140" height="180" rx="8" stroke="currentColor" stroke-width="1.5" />
        <!-- Lignes du document -->
        <line x1="205" y1="160" x2="295" y2="160" stroke="currentColor" stroke-width="1" opacity="0.5" />
        <line x1="205" y1="180" x2="280" y2="180" stroke="currentColor" stroke-width="1" opacity="0.3" />
        <line x1="205" y1="200" x2="290" y2="200" stroke="currentColor" stroke-width="1" opacity="0.4" />
        <line x1="205" y1="220" x2="260" y2="220" stroke="currentColor" stroke-width="1" opacity="0.3" />
        <line x1="205" y1="240" x2="275" y2="240" stroke="currentColor" stroke-width="1" opacity="0.3" />
        <!-- Checkbox icônes -->
        <rect x="205" y="260" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1" opacity="0.5" />
        <path d="M208 266 L210 268 L214 264" stroke="currentColor" stroke-width="1" opacity="0.5" />
        <rect x="225" y="262" width="50" height="8" rx="2" fill="currentColor" opacity="0.15" />
        <!-- Loupe -->
        <circle cx="330" cy="320" r="40" stroke="currentColor" stroke-width="1.5" />
        <line x1="358" y1="348" x2="390" y2="380" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        <!-- Document secondaire derrière -->
        <rect x="160" y="140" width="140" height="180" rx="8" stroke="currentColor" stroke-width="0.8" opacity="0.3" />
        <!-- Points décoratifs -->
        <circle cx="140" cy="160" r="6" fill="currentColor" opacity="0.3" />
        <circle cx="370" cy="150" r="8" fill="currentColor" opacity="0.3" />
      </svg>
    </div>

    <!-- Illustration gauche — Grille de fichiers -->
    <div class="absolute left-0 top-1/2 -translate-y-1/2 opacity-[0.15] hidden lg:block pointer-events-none">
      <svg aria-hidden="true" width="400" height="400" viewBox="0 0 400 400" fill="none" class="text-emerald-800">
        <!-- Dossier -->
        <path d="M80 140 L80 300 L320 300 L320 160 L200 160 L180 140Z" stroke="currentColor" stroke-width="1.5" rx="6" fill="none" />
        <!-- Fichiers dans le dossier -->
        <rect x="110" y="190" width="70" height="85" rx="4" stroke="currentColor" stroke-width="1" opacity="0.5" />
        <rect x="120" y="210" width="50" height="4" rx="1" fill="currentColor" opacity="0.3" />
        <rect x="120" y="220" width="40" height="4" rx="1" fill="currentColor" opacity="0.2" />
        <rect x="120" y="230" width="45" height="4" rx="1" fill="currentColor" opacity="0.2" />
        <rect x="200" y="190" width="70" height="85" rx="4" stroke="currentColor" stroke-width="1" opacity="0.5" />
        <rect x="210" y="210" width="50" height="4" rx="1" fill="currentColor" opacity="0.3" />
        <rect x="210" y="220" width="40" height="4" rx="1" fill="currentColor" opacity="0.2" />
        <rect x="210" y="230" width="45" height="4" rx="1" fill="currentColor" opacity="0.2" />
        <!-- Flèches de connexion -->
        <path d="M155 120 L155 140" stroke="currentColor" stroke-width="1" opacity="0.4" />
        <path d="M245 120 L245 140" stroke="currentColor" stroke-width="1" opacity="0.4" />
        <circle cx="155" cy="115" r="8" stroke="currentColor" stroke-width="1" opacity="0.4" />
        <circle cx="245" cy="115" r="8" stroke="currentColor" stroke-width="1" opacity="0.4" />
      </svg>
    </div>

    <!-- Contenu -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 py-24 md:py-32 text-center">
      <div class="max-w-3xl mx-auto">
        <div class="badge bg-emerald-100 text-emerald-700 mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          {tp('teeqode', 'hero.badge', lang)}
        </div>

        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold text-gray-900 leading-[1.1] mb-4 tracking-tight" set:html={tp('teeqode', 'hero.title', lang)}></h1>
        <p class="text-base md:text-lg lg:text-xl text-gray-700 leading-relaxed mb-8 md:mb-10 max-w-xl mx-auto">
          {tp('teeqode', 'hero.subtitle', lang)}
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={EXTERNAL_LINKS.teeqode} target="_blank" rel="noopener noreferrer" class="btn-primary text-base">
            {t('cta.tryTeeqode', lang)}
            <svg aria-hidden="true" class="inline-block ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <a href={`${getLocalizedPath('/', lang)}#contact`} class="btn-outline text-base">
            {t('cta.contact', lang)}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- C'est quoi TEEQODE ? -->
  <section class="section-padding bg-white">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <div class="badge bg-teal-50 text-teal-700 mx-auto mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
        {tp('teeqode', 'what.badge', lang)}
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-6" set:html={tp('teeqode', 'what.title', lang)}></h2>
      <p class="text-gray-600 text-base md:text-lg leading-relaxed">
        {tp('teeqode', 'what.text', lang)}
      </p>
    </div>
  </section>

  <!-- 3 points forts -->
  <section class="section-padding bg-gradient-to-b from-teal-50/40 to-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-10 md:mb-16 fade-in">
        <div class="badge bg-teal-50 text-teal-700 mx-auto mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
          {tp('teeqode', 'why.badge', lang)}
        </div>
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4" set:html={tp('teeqode', 'why.title', lang)}></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8 stagger-children">
        <!-- Centralisation sécurisée -->
        <div class="glass-card p-6 md:p-10 fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-teal-100 to-cyan-100 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{tp('teeqode', 'why.card1.title', lang)}</h3>
          <p class="text-gray-500 leading-relaxed">{tp('teeqode', 'why.card1.text', lang)}</p>
        </div>

        <!-- Conformité automatique -->
        <div class="glass-card p-6 md:p-10 fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-100 to-teal-100 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{tp('teeqode', 'why.card2.title', lang)}</h3>
          <p class="text-gray-500 leading-relaxed">{tp('teeqode', 'why.card2.text', lang)}</p>
        </div>

        <!-- Sur-mesure & modulaire -->
        <div class="glass-card p-6 md:p-10 fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-cyan-100 to-teal-100 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{tp('teeqode', 'why.card3.title', lang)}</h3>
          <p class="text-gray-500 leading-relaxed">{tp('teeqode', 'why.card3.text', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative overflow-hidden py-12 md:py-24">
    <div class="absolute inset-0 bg-gradient-to-r from-teal-600 via-cyan-600 to-emerald-600"></div>
    <div class="absolute inset-0 lines-pattern opacity-10"></div>
    <div class="blob w-64 md:w-[500px] h-64 md:h-[500px] bg-white/10 -top-32 -right-32"></div>
    <div class="blob w-80 h-80 bg-white/10 -bottom-20 -left-20" style="animation-delay: 3s;"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-bold text-white mb-6">
        {tp('teeqode', 'cta.title', lang)}
      </h2>
      <p class="text-teal-100 text-base md:text-lg mb-6 md:mb-10 max-w-2xl mx-auto">
        {tp('teeqode', 'cta.text', lang)}
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={EXTERNAL_LINKS.teeqode} target="_blank" rel="noopener noreferrer" class="inline-block bg-white text-teal-700 px-6 py-3 md:px-10 md:py-4 rounded-full font-semibold hover:bg-teal-50 transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 text-lg">
          {t('cta.tryTeeqode', lang)}
          <svg aria-hidden="true" class="inline-block ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
        <a href={`${getLocalizedPath('/', lang)}#contact`} class="inline-block border-2 border-white text-white px-6 py-3 md:px-10 md:py-4 rounded-full font-semibold hover:bg-white/10 transition-all duration-300 text-lg">
          {t('cta.contactShort', lang)}
        </a>
      </div>
    </div>
  </section>

</Layout>
