---
import Layout from '../layouts/Layout.astro';
import { EXTERNAL_LINKS } from '../lib/constants';
import { t, tp, getLocalizedPath, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const lang = locale;
---

<Layout title={tp('kuck', 'hero.badge', lang) + ' – Digital Factory'} description={tp('kuck', 'hero.subtitle', lang)} locale={lang}>

  <!-- Hero Section (hauteur réduite) -->
  <section class="relative overflow-hidden min-h-[50vh] md:min-h-[60vh] flex items-center">
    <!-- Fond dégradé teal/cyan -->
    <div class="absolute inset-0 bg-gradient-to-br from-teal-100 via-cyan-50 to-emerald-100"></div>
    <div class="absolute inset-0 bg-gradient-to-tr from-teal-200/40 via-transparent to-cyan-200/30"></div>

    <!-- Blobs décoratifs -->
    <div class="blob w-64 md:w-[500px] h-64 md:h-[500px] bg-teal-300/50 -top-20 -left-32" style="animation-delay: 0s;"></div>
    <div class="blob w-48 md:w-96 h-48 md:h-96 bg-cyan-300/40 bottom-20 right-10" style="animation-delay: 2s;"></div>
    <div class="blob w-40 md:w-72 h-40 md:h-72 bg-emerald-200/40 top-1/2 left-1/2" style="animation-delay: 4s;"></div>

    <!-- Motif lignes -->
    <div class="absolute inset-0 lines-pattern opacity-40"></div>

    <!-- Vagues animées -->
    <div class="absolute bottom-0 left-0 right-0 pointer-events-none">
      <svg aria-hidden="true" class="absolute bottom-0 w-[200%] animate-wave-slow" viewBox="0 0 2880 180" preserveAspectRatio="none" style="height: 100px;">
        <path d="M0 100C240 140 480 60 720 100C960 140 1200 60 1440 100C1680 140 1920 60 2160 100C2400 140 2640 60 2880 100V180H0Z" fill="rgba(255,255,255,0.3)" />
      </svg>
      <svg aria-hidden="true" class="absolute bottom-0 w-[200%] animate-wave-mid" viewBox="0 0 2880 180" preserveAspectRatio="none" style="height: 80px;">
        <path d="M0 80C200 130 400 40 600 80C800 120 1000 30 1200 80C1400 130 1600 40 1800 80C2000 120 2200 30 2400 80C2600 130 2800 40 2880 80V180H0Z" fill="rgba(255,255,255,0.5)" />
      </svg>
      <svg aria-hidden="true" class="absolute bottom-0 w-[200%] animate-wave-fast" viewBox="0 0 2880 180" preserveAspectRatio="none" style="height: 60px;">
        <path d="M0 90C180 130 360 50 540 90C720 130 900 50 1080 90C1260 130 1440 50 1620 90C1800 130 1980 50 2160 90C2340 130 2520 50 2700 90C2880 130 2880 90 2880 90V180H0Z" fill="white" />
      </svg>
    </div>

    <!-- Illustration décorative droite -->
    <div class="absolute right-0 top-1/2 -translate-y-1/2 opacity-10 hidden lg:block pointer-events-none">
      <svg aria-hidden="true" width="500" height="500" viewBox="0 0 500 500" fill="none" class="text-teal-800">
        <circle cx="250" cy="250" r="100" stroke="currentColor" stroke-width="1" />
        <circle cx="250" cy="250" r="150" stroke="currentColor" stroke-width="0.5" stroke-dasharray="8 4" />
        <circle cx="250" cy="250" r="200" stroke="currentColor" stroke-width="0.5" />
        <line x1="250" y1="50" x2="250" y2="450" stroke="currentColor" stroke-width="0.5" />
        <line x1="50" y1="250" x2="450" y2="250" stroke="currentColor" stroke-width="0.5" />
        <rect x="210" y="210" width="80" height="80" stroke="currentColor" stroke-width="1.5" rx="8" />
        <circle cx="160" cy="160" r="8" fill="currentColor" opacity="0.5" />
        <circle cx="340" cy="160" r="8" fill="currentColor" opacity="0.5" />
        <circle cx="160" cy="340" r="8" fill="currentColor" opacity="0.5" />
        <circle cx="340" cy="340" r="8" fill="currentColor" opacity="0.5" />
        <path d="M250 150 L340 250 L250 350 L160 250Z" stroke="currentColor" stroke-width="0.5" fill="none" />
      </svg>
    </div>

    <!-- Illustration décorative gauche -->
    <div class="absolute left-0 top-1/2 -translate-y-1/2 opacity-[0.07] hidden lg:block pointer-events-none">
      <svg aria-hidden="true" width="400" height="400" viewBox="0 0 400 400" fill="none" class="text-teal-800">
        <circle cx="200" cy="200" r="80" stroke="currentColor" stroke-width="1" />
        <circle cx="200" cy="200" r="120" stroke="currentColor" stroke-width="0.5" stroke-dasharray="6 3" />
        <circle cx="200" cy="200" r="160" stroke="currentColor" stroke-width="0.5" />
        <path d="M200 40 L360 200 L200 360 L40 200Z" stroke="currentColor" stroke-width="0.5" fill="none" />
        <circle cx="120" cy="120" r="6" fill="currentColor" opacity="0.4" />
        <circle cx="280" cy="120" r="6" fill="currentColor" opacity="0.4" />
        <circle cx="120" cy="280" r="6" fill="currentColor" opacity="0.4" />
        <circle cx="280" cy="280" r="6" fill="currentColor" opacity="0.4" />
      </svg>
    </div>

    <!-- Contenu -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 py-16 md:py-24 text-center">
      <div class="max-w-3xl mx-auto">
        <div class="badge bg-teal-100 text-teal-700 mb-6">{tp('kuck', 'hero.badge', lang)}</div>

        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold text-gray-900 leading-[1.1] mb-4 tracking-tight" set:html={tp('kuck', 'hero.title', lang)}></h1>
        <p class="text-base md:text-lg lg:text-xl text-gray-700 leading-relaxed mb-8 md:mb-10 max-w-xl mx-auto">
          {tp('kuck', 'hero.subtitle', lang)}
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={EXTERNAL_LINKS.kuck} target="_blank" rel="noopener noreferrer" class="btn-primary text-base">
            {tp('kuck', 'hero.cta.primary', lang)}
            <svg aria-hidden="true" class="inline-block ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <a href={`${getLocalizedPath('/', lang)}#contact`} class="btn-outline text-base">
            {t('cta.contact', lang)}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Nos 3 services (cartes agrandies + liens) -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-10 md:mb-16 fade-in">
        <div class="badge bg-teal-50 text-teal-700 mx-auto mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
          {tp('kuck', 'services.badge', lang)}
        </div>
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4" set:html={tp('kuck', 'services.title', lang)}></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8 stagger-children">
        <!-- Numérisation 3D -->
        <div class="relative bg-gradient-to-br from-teal-50 to-cyan-50 rounded-3xl p-8 md:p-12 fade-in group hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 border border-teal-100/50 overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-teal-200/30 to-transparent rounded-bl-full"></div>
          <div class="relative">
            <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-teal-500 to-cyan-600 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-teal-200">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-3">{tp('kuck', 'services.card1.title', lang)}</h3>
            <p class="text-gray-600 leading-relaxed mb-6">{tp('kuck', 'services.card1.text', lang)}</p>
            <a href="https://www.kuck.lu/services-3d.html" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-teal-600 font-semibold hover:text-teal-700 transition-colors group/link">
              {t('cta.learnMore', lang)}
              <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Captation Drone -->
        <div class="relative bg-gradient-to-br from-emerald-50 to-teal-50 rounded-3xl p-8 md:p-12 fade-in group hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 border border-emerald-100/50 overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-emerald-200/30 to-transparent rounded-bl-full"></div>
          <div class="relative">
            <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-emerald-200">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-3">{tp('kuck', 'services.card2.title', lang)}</h3>
            <p class="text-gray-600 leading-relaxed mb-6">{tp('kuck', 'services.card2.text', lang)}</p>
            <a href="https://www.kuck.lu/captation-drone.html" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-emerald-600 font-semibold hover:text-emerald-700 transition-colors group/link">
              {t('cta.learnMore', lang)}
              <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Visites virtuelles -->
        <div class="relative bg-gradient-to-br from-cyan-50 to-teal-50 rounded-3xl p-8 md:p-12 fade-in group hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 border border-cyan-100/50 overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-cyan-200/30 to-transparent rounded-bl-full"></div>
          <div class="relative">
            <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-cyan-500 to-teal-600 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-cyan-200">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
              </svg>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-3">{tp('kuck', 'services.card3.title', lang)}</h3>
            <p class="text-gray-600 leading-relaxed mb-6">{tp('kuck', 'services.card3.text', lang)}</p>
            <a href="https://www.kuck.lu/services-3d.html" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-cyan-600 font-semibold hover:text-cyan-700 transition-colors group/link">
              {t('cta.learnMore', lang)}
              <svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pour quels secteurs ? (fond gris pour contraste) -->
  <section class="section-padding bg-gray-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-10 md:mb-16 fade-in">
        <div class="badge bg-teal-50 text-teal-700 mx-auto mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
          {tp('kuck', 'sectors.badge', lang)}
        </div>
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4" set:html={tp('kuck', 'sectors.title', lang)}></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8 stagger-children">
        <!-- Industrie & construction -->
        <div class="glass-card p-8 md:p-10 fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-teal-100 to-cyan-100 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-3">{tp('kuck', 'sectors.card1.title', lang)}</h3>
          <p class="text-gray-600 leading-relaxed">{tp('kuck', 'sectors.card1.text', lang)}</p>
        </div>

        <!-- Restauration -->
        <div class="glass-card p-8 md:p-10 fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-100 to-teal-100 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-3">{tp('kuck', 'sectors.card2.title', lang)}</h3>
          <p class="text-gray-600 leading-relaxed">{tp('kuck', 'sectors.card2.text', lang)}</p>
        </div>

        <!-- Hôtellerie -->
        <div class="glass-card p-8 md:p-10 fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-cyan-100 to-teal-100 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-3">{tp('kuck', 'sectors.card3.title', lang)}</h3>
          <p class="text-gray-600 leading-relaxed">{tp('kuck', 'sectors.card3.text', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3 points forts (fond gradient teal pour contraste) -->
  <section class="section-padding bg-gradient-to-b from-teal-50/60 via-cyan-50/30 to-teal-50/60">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-10 md:mb-16 fade-in">
        <div class="badge bg-teal-100 text-teal-700 mx-auto mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
          {tp('kuck', 'why.badge', lang)}
        </div>
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4" set:html={tp('kuck', 'why.title', lang)}></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8 stagger-children">
        <!-- Précision -->
        <div class="glass-card p-8 md:p-10 fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-teal-500 to-cyan-600 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-teal-200/50">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
          </div>
          <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-3">{tp('kuck', 'why.card1.title', lang)}</h3>
          <p class="text-gray-600 leading-relaxed">{tp('kuck', 'why.card1.text', lang)}</p>
        </div>

        <!-- Rapidité & sécurité -->
        <div class="glass-card p-8 md:p-10 fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-emerald-200/50">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-3">{tp('kuck', 'why.card2.title', lang)}</h3>
          <p class="text-gray-600 leading-relaxed">{tp('kuck', 'why.card2.text', lang)}</p>
        </div>

        <!-- Jumeaux numériques -->
        <div class="glass-card p-8 md:p-10 fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-cyan-500 to-teal-600 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-cyan-200/50">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
            </svg>
          </div>
          <h3 class="text-xl md:text-2xl font-bold text-gray-900 mb-3">{tp('kuck', 'why.card3.title', lang)}</h3>
          <p class="text-gray-600 leading-relaxed">{tp('kuck', 'why.card3.text', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ils nous ont fait confiance -->
  <section class="section-padding bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-10 md:mb-16 fade-in">
        <div class="badge bg-teal-50 text-teal-700 mx-auto mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
          {tp('kuck', 'projects.badge', lang)}
        </div>
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4" set:html={tp('kuck', 'projects.title', lang)}></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8 stagger-children">
        <!-- Restaurant V&V Délice -->
        <div class="glass-card overflow-hidden fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500 flex flex-col">
          <a href="https://vandvdelice.lu/" target="_blank" rel="noopener noreferrer" class="block aspect-video relative overflow-hidden flex-shrink-0">
            <img src="/images/vv-delice.webp" alt="Restaurant V&V Délice" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent flex items-end p-4">
              <span class="text-white font-semibold text-sm uppercase tracking-wide flex items-center gap-1.5">
                {tp('kuck', 'projects.cta2', lang)}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
              </span>
            </div>
          </a>
          <div class="p-6 md:p-8 flex flex-col flex-1">
