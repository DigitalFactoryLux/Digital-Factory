---
import Layout from '../layouts/Layout.astro';
import WaveDivider from '../components/WaveDivider.astro';
import { t, tp, getLocalizedPath, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const lang = locale;
---

<Layout title={`Agent Lift - ${tp('agentlift', 'hero.subtitle', lang)}`} description={tp('agentlift', 'hero.subtitle', lang)} locale={lang}>

  <!-- Hero Section -->
  <section class="relative overflow-hidden min-h-[70vh] md:min-h-[85vh] flex items-center">
    <!-- Fond dégradé cyan/emerald dominant (plus intense) -->
    <div class="absolute inset-0 bg-gradient-to-br from-cyan-200 via-emerald-100 to-teal-100"></div>
    <div class="absolute inset-0 bg-gradient-to-tr from-emerald-300/30 via-transparent to-cyan-200/20"></div>

    <!-- Blobs décoratifs (emerald/cyan plus marqué) -->
    <div class="blob w-40 md:w-64 lg:w-[500px] h-40 md:h-64 lg:h-[500px] bg-emerald-400/60 -top-10 left-1/4 md:-top-20 md:left-1/3" style="animation-delay: 0s;"></div>
    <div class="blob w-32 md:w-48 lg:w-96 h-32 md:h-48 lg:h-96 bg-cyan-300/50 bottom-10 -left-5 md:bottom-20 md:-left-10" style="animation-delay: 2s;"></div>
    <div class="blob w-28 md:w-40 lg:w-72 h-28 md:h-40 lg:h-72 bg-teal-300/30 top-1/3 right-5 md:right-10" style="animation-delay: 4s;"></div>

    <!-- Motif lignes -->
    <div class="absolute inset-0 lines-pattern opacity-40"></div>

    <!-- Vagues animées -->
    <div class="absolute bottom-0 left-0 right-0 pointer-events-none">
      <svg aria-hidden="true" class="absolute bottom-0 w-[200%] animate-wave-slow" viewBox="0 0 2880 180" preserveAspectRatio="none" style="height: 100px;">
        <path d="M0 100C240 140 480 60 720 100C960 140 1200 60 1440 100C1680 140 1920 60 2160 100C2400 140 2640 60 2880 100V180H0Z" fill="rgba(255,255,255,0.3)" />
      </svg>
      <svg aria-hidden="true" class="absolute bottom-0 w-[200%] animate-wave-mid" viewBox="0 0 2880 180" preserveAspectRatio="none" style="height: 80px;">
        <path d="M0 80C200 130 400 40 600 80C800 120 1000 30 1200 80C1400 130 1600 40 1800 80C2000 120 2200 30 2400 80C2600 130 2800 40 2880 80V180H0Z" fill="rgba(255,255,255,0.5)" />
      </svg>
      <svg aria-hidden="true" class="absolute bottom-0 w-[200%] animate-wave-fast" viewBox="0 0 2880 180" preserveAspectRatio="none" style="height: 60px;">
        <path d="M0 90C180 130 360 50 540 90C720 130 900 50 1080 90C1260 130 1440 50 1620 90C1800 130 1980 50 2160 90C2340 130 2520 50 2700 90C2880 130 2880 90 2880 90V180H0Z" fill="white" />
      </svg>
    </div>

    <!-- Illustration droite — Robot IA avec bulles de chat -->
    <div class="absolute right-0 top-1/2 -translate-y-1/2 opacity-20 hidden lg:block pointer-events-none">
      <svg aria-hidden="true" width="500" height="500" viewBox="0 0 500 500" fill="none" class="text-cyan-800">
        <!-- Tête du robot -->
        <rect x="200" y="170" width="100" height="80" rx="16" stroke="currentColor" stroke-width="1.5" />
        <!-- Antenne -->
        <line x1="250" y1="170" x2="250" y2="145" stroke="currentColor" stroke-width="1.5" />
        <circle cx="250" cy="140" r="8" stroke="currentColor" stroke-width="1.5" />
        <!-- Yeux -->
        <circle cx="230" cy="205" r="10" stroke="currentColor" stroke-width="1.5" />
        <circle cx="270" cy="205" r="10" stroke="currentColor" stroke-width="1.5" />
        <circle cx="230" cy="205" r="4" fill="currentColor" opacity="0.5" />
        <circle cx="270" cy="205" r="4" fill="currentColor" opacity="0.5" />
        <!-- Bouche -->
        <path d="M235 230 Q250 240 265 230" stroke="currentColor" stroke-width="1" fill="none" />
        <!-- Corps -->
        <rect x="215" y="260" width="70" height="50" rx="10" stroke="currentColor" stroke-width="1" opacity="0.5" />
        <!-- Bulle de chat droite -->
        <rect x="320" y="150" width="100" height="50" rx="12" stroke="currentColor" stroke-width="1" />
        <path d="M320 180 L305 190 L320 190" fill="none" stroke="currentColor" stroke-width="1" />
        <line x1="340" y1="168" x2="400" y2="168" stroke="currentColor" stroke-width="0.8" opacity="0.5" />
        <line x1="340" y1="180" x2="385" y2="180" stroke="currentColor" stroke-width="0.8" opacity="0.3" />
        <!-- Bulle de chat gauche -->
        <rect x="90" y="210" width="90" height="45" rx="12" stroke="currentColor" stroke-width="1" />
        <path d="M180 235 L195 245 L180 240" fill="none" stroke="currentColor" stroke-width="1" />
        <line x1="110" y1="228" x2="160" y2="228" stroke="currentColor" stroke-width="0.8" opacity="0.5" />
        <line x1="110" y1="238" x2="150" y2="238" stroke="currentColor" stroke-width="0.8" opacity="0.3" />
        <!-- Ondes IA -->
        <circle cx="250" cy="200" r="90" stroke="currentColor" stroke-width="0.5" stroke-dasharray="6 4" opacity="0.4" />
        <circle cx="250" cy="200" r="130" stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 6" opacity="0.2" />
        <!-- Points décoratifs -->
        <circle cx="150" cy="150" r="5" fill="currentColor" opacity="0.3" />
        <circle cx="350" cy="300" r="5" fill="currentColor" opacity="0.3" />
        <circle cx="380" cy="130" r="4" fill="currentColor" opacity="0.2" />
      </svg>
    </div>

    <!-- Illustration gauche — Cerveau avec circuits -->
    <div class="absolute left-0 top-1/2 -translate-y-1/2 opacity-[0.15] hidden lg:block pointer-events-none">
      <svg aria-hidden="true" width="400" height="400" viewBox="0 0 400 400" fill="none" class="text-cyan-800">
        <!-- Cerveau simplifié -->
        <path d="M200 100 C140 100 90 140 90 200 C90 260 140 310 200 310 C260 310 310 260 310 200 C310 140 260 100 200 100" stroke="currentColor" stroke-width="1.5" fill="none" />
        <!-- Division cerveau -->
        <path d="M200 100 C200 150 180 200 200 250 C220 300 200 310 200 310" stroke="currentColor" stroke-width="1" fill="none" />
        <!-- Connexions neuronales -->
        <circle cx="160" cy="160" r="8" stroke="currentColor" stroke-width="1" />
        <circle cx="240" cy="160" r="8" stroke="currentColor" stroke-width="1" />
        <circle cx="150" cy="220" r="8" stroke="currentColor" stroke-width="1" />
        <circle cx="250" cy="220" r="8" stroke="currentColor" stroke-width="1" />
        <circle cx="200" cy="270" r="8" stroke="currentColor" stroke-width="1" />
        <!-- Lignes de connexion -->
        <line x1="168" y1="160" x2="232" y2="160" stroke="currentColor" stroke-width="0.8" />
        <line x1="160" y1="168" x2="150" y2="212" stroke="currentColor" stroke-width="0.8" />
        <line x1="240" y1="168" x2="250" y2="212" stroke="currentColor" stroke-width="0.8" />
        <line x1="155" y1="228" x2="192" y2="265" stroke="currentColor" stroke-width="0.8" />
        <line x1="245" y1="228" x2="208" y2="265" stroke="currentColor" stroke-width="0.8" />
        <!-- Circuits sortants -->
        <line x1="90" y1="200" x2="50" y2="200" stroke="currentColor" stroke-width="0.8" opacity="0.5" />
        <line x1="310" y1="200" x2="350" y2="200" stroke="currentColor" stroke-width="0.8" opacity="0.5" />
        <circle cx="45" cy="200" r="5" fill="currentColor" opacity="0.3" />
        <circle cx="355" cy="200" r="5" fill="currentColor" opacity="0.3" />
      </svg>
    </div>

    <!-- Contenu -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 py-24 md:py-32 text-center">
      <div class="max-w-3xl mx-auto">
        <div class="badge bg-emerald-100 text-emerald-700 mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          {tp('agentlift', 'hero.badge', lang)}
        </div>

        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold text-gray-900 leading-[1.1] mb-4 tracking-tight" set:html={tp('agentlift', 'hero.title', lang)}></h1>
        <p class="text-base md:text-lg lg:text-xl text-gray-700 leading-relaxed mb-8 md:mb-10 max-w-xl mx-auto">
          {tp('agentlift', 'hero.subtitle', lang)}
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={`${getLocalizedPath('/', lang)}#contact`} class="btn-primary text-base">
            {t('cta.contact', lang)}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- C'est quoi Agent Lift ? -->
  <section class="section-padding bg-white">
    <div class="max-w-3xl mx-auto text-center fade-in">
      <div class="badge bg-teal-50 text-teal-700 mx-auto mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
        {tp('agentlift', 'what.badge', lang)}
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-6" set:html={tp('agentlift', 'what.title', lang)}></h2>
      <p class="text-gray-600 text-base md:text-lg leading-relaxed">
        {tp('agentlift', 'what.text', lang)}
      </p>
    </div>
  </section>

  <!-- Démo vidéo -->
  <section class="relative bg-gradient-to-b from-teal-50/60 via-teal-50/40 to-teal-50/60">
    <WaveDivider flip={true} color="#ecfdf5" />
    <div class="section-padding">
      <div class="max-w-4xl mx-auto fade-in">
        <div class="text-center mb-8 md:mb-12">
          <div class="badge bg-teal-100 text-teal-700 mx-auto mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
            {tp('agentlift', 'demo.badge', lang)}
          </div>
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-4">{tp('agentlift', 'demo.title', lang)}</h2>
        </div>
        <div class="relative rounded-2xl overflow-hidden shadow-2xl border border-gray-200/50">
          <iframe
            class="w-full aspect-video border-0"
            src="https://www.youtube.com/embed/LN76xe4n5e4"
            title="Agent Lift Demo"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
    <WaveDivider color="white" />
  </section>

  <!-- 3 points forts -->
  <section class="section-padding bg-gradient-to-b from-teal-50/40 via-emerald-50/30 to-teal-50/40">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-10 md:mb-16 fade-in">
        <div class="badge bg-teal-50 text-teal-700 mx-auto mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
          {tp('agentlift', 'why.badge', lang)}
        </div>
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4" set:html={tp('agentlift', 'why.title', lang)}></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8 stagger-children">
        <!-- IA Multimodale -->
        <div class="glass-card p-6 md:p-10 fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-teal-100 to-cyan-100 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{tp('agentlift', 'why.card1.title', lang)}</h3>
          <p class="text-gray-500 leading-relaxed">{tp('agentlift', 'why.card1.text', lang)}</p>
        </div>

        <!-- Sécurité Chantier -->
        <div class="glass-card p-6 md:p-10 fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-100 to-teal-100 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{tp('agentlift', 'why.card2.title', lang)}</h3>
          <p class="text-gray-500 leading-relaxed">{tp('agentlift', 'why.card2.text', lang)}</p>
        </div>

        <!-- Manuels & Multi-langue -->
        <div class="glass-card p-6 md:p-10 fade-in group hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-cyan-100 to-teal-100 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{tp('agentlift', 'why.card3.title', lang)}</h3>
          <p class="text-gray-500 leading-relaxed">{tp('agentlift', 'why.card3.text', lang)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <WaveDivider flip={true} color="#0d9488" />
  <section class="relative overflow-hidden py-12 md:py-24">
    <div class="absolute inset-0 bg-gradient-to-r from-teal-600 via-cyan-600 to-emerald-600"></div>
    <div class="absolute inset-0 lines-pattern opacity-10"></div>
    <div class="blob w-64 md:w-[500px] h-64 md:h-[500px] bg-white/10 -top-32 -right-32"></div>
    <div class="blob w-80 h-80 bg-white/10 -bottom-20 -left-20" style="animation-delay: 3s;"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-bold text-white mb-6">
        {tp('agentlift', 'cta.title', lang)}
      </h2>
      <p class="text-white/90 text-base md:text-lg mb-6 md:mb-10 max-w-2xl mx-auto">
        {tp('agentlift', 'cta.text', lang)}
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`${getLocalizedPath('/', lang)}#contact`} class="inline-block bg-white text-teal-700 px-6 py-3 md:px-10 md:py-4 rounded-full font-semibold hover:bg-teal-50 transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 text-lg">
          {t('cta.contact', lang)}
        </a>
      </div>
    </div>
  </section>

</Layout>
